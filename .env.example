# ============================================================
# MSI BF - Variables d'environnement
# Copier vers .env et adapter les valeurs
# NE JAMAIS COMMITTER .env dans git
# ============================================================

# Application
NODE_ENV=development
APP_NAME=MSI-BF-Gestion
APP_URL=http://localhost:3000
PORT=3000
FRONTEND_URL=http://localhost:5174

# Base de données SQLite (Plus simple, aucune configuration requise!)
# Le fichier sera créé automatiquement dans le dossier /data
DB_NAME=msi_gestion.db

# JWT
JWT_SECRET=msi_super_secret_key_2026_!@#_longue_et_complexe
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@mariestopes-bf.org
SMTP_PASS=MOT_DE_PASSE_EMAIL
EMAIL_FROM="MSI BF Gestion <noreply@mariestopes-bf.org>"

# Stockage fichiers
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES=image/jpeg,image/png,application/pdf,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# Sécurité
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5
SESSION_LOCK_MINUTES=15
INACTIVITY_DAYS=45
RESET_TOKEN_HOURS=24
PASSWORD_EXPIRY_DAYS=90
RESET_TOKEN_HOURS=24

# Logs
LOG_LEVEL=info
LOG_DIR=/app/logs

# RGPD
LOG_RETENTION_DAYS=365
ANONYMIZE_LOGS_AFTER_DAYS=730
